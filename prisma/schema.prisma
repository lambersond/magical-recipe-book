// -------------------------
// Many-to-many relationships
// --------------------------

model BiomeIngredient {
  biome       Biome      @relation(fields: [biomeId], references: [id])
  biomeId     String
  ingredient  Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String

  @@id([biomeId, ingredientId])
}
